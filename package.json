{
  "name": "@olayemii/ccswitch",
  "version": "0.2.1",
  "description": "Switch between Claude Code accounts and profiles (login, API key, Bedrock, custom Anthropic-compatible endpoints) globally or per-shell, with expiry tracking and liveness probes.",
  "type": "module",
  "bin": { "ccswitch": "dist/bin.js" },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "author": "Olayemii Garuba",
  "homepage": "https://olayemii.github.io/ccswitch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olayemii/ccswitch.git"
  },
  "bugs": {
    "url": "https://github.com/olayemii/ccswitch/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "cli",
    "profiles",
    "account-switcher",
    "credentials",
    "bedrock"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsup": "^8.2.0",
    "@types/node": "^20.14.0"
  }
}
