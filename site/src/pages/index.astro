---
import TerminalDemo from '../components/TerminalDemo.astro'
const title = 'ccswitch — Claude account switcher'
const description = 'Switch between Claude Code profiles in seconds. Multi-account, per-shell isolation, expiry tracking.'
---

<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="stylesheet" href="/styles/landing.css" />
</head>
<body>
  <main>
    <section class="hero">
      <h1>One machine. Many Claude accounts.</h1>
      <p class="subheadline">Switch Claude Code profiles — logins, API keys, Bedrock — globally or per-shell, with expiry tracking and liveness probes.</p>
      <TerminalDemo />
      <div class="ctas">
        <a href="/docs/getting-started/installation" class="btn btn-primary">Get Started</a>
        <div class="install-snippet">
          <code>npm install -g ccswitch</code>
          <button class="copy-btn" data-copy="npm install -g ccswitch" aria-label="Copy install command">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M3 11V3a1 1 0 0 1 1-1h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="feature-card">
        <h3>Multi-account</h3>
        <p>Login, API key, Bedrock SigV4, and Bedrock API key — all managed as named profiles.</p>
      </div>
      <div class="feature-card">
        <h3>Per-shell isolation</h3>
        <p>Run different accounts in parallel terminals. Each shell gets its own profile, config, and history.</p>
      </div>
      <div class="feature-card">
        <h3>Expiry tracking</h3>
        <p>Short-lived tokens are tracked automatically. Expired keys are blocked at switch time with a clear refresh path.</p>
      </div>
      <div class="feature-card">
        <h3>Cross-platform</h3>
        <p>macOS, Windows, and Linux. Secrets stored in the OS keychain — never in plaintext config files.</p>
      </div>
    </section>
  </main>

  <footer>
    <a href="https://github.com/ccswitch/ccswitch">GitHub</a>
    <a href="https://www.npmjs.com/package/ccswitch">npm</a>
    <span>MIT License</span>
  </footer>

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy')
        if (text) navigator.clipboard.writeText(text)
      })
    })
  </script>
</body>
</html>
