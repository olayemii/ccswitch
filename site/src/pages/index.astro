---
import TerminalDemo from '../components/TerminalDemo.astro'
const title = 'ccswitch — Claude account switcher'
const description = 'Switch between Claude Code profiles in seconds. Multi-account, per-shell isolation, expiry tracking.'
// Normalise to exactly one trailing slash so `${base}foo` never collapses to
// `/ccswitchfoo` when BASE_URL has no trailing slash.
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/'
---

<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href={`${base}styles/landing.css`} />
</head>
<body>
  <header class="topbar">
    <span class="wordmark">ccswitch</span>
    <nav class="topnav">
      <a href={`${base}getting-started/installation`}>Docs</a>
      <a href="https://github.com/olayemii/ccswitch" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        <span>GitHub</span>
      </a>
    </nav>
  </header>
  <main>
    <section class="hero">
      <div class="hero-copy">
        <h1>One machine. Many Claude accounts.</h1>
        <p class="subheadline">Switch Claude Code profiles (logins, API keys, Bedrock) globally or per&#8209;shell, with expiry tracking and liveness probes.</p>
        <div class="ctas">
          <div class="install-snippet">
            <code>npm install -g ccswitch</code>
            <button class="copy-btn" data-copy="npm install -g ccswitch" aria-label="Copy install command">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M3 11V3a1 1 0 0 1 1-1h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <TerminalDemo />
      </div>
    </section>
  </main>

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy')
        if (text) navigator.clipboard.writeText(text)
      })
    })
  </script>
</body>
</html>
